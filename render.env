SeedData__AdminPassword=replace-with-secure-admin-password
SeedData__DefaultUserEmail=attendee@example.com
SeedData__DefaultUserPassword=replace-with-secure-attendee-password

# Optional Google sign-in. Remove or leave empty if not using Google auth.
Authentication__Google__ClientIds__0=

# Optional Apple sign-in. Remove or leave empty if not using Apple auth.
Authentication__Apple__ClientIds__0=
