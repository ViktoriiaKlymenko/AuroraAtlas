ASPNETCORE_ENVIRONMENT=Production

# Render sets PORT automatically for web services. Keep this only if you are uploading to a service that expects it.
# PORT=10000

# Database: Neon/Postgres connection string for the API.
DATABASE_URL=postgresql://neondb_owner:npg_WniQhyT2LZG5@ep-quiet-bonus-at3rugm9.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT settings. Generate a strong random signing key with at least 32 characters.
Jwt__SigningKey=replace-with-a-long-random-production-secret-at-least-32-characters
Jwt__Issuer=EventApp.Api
Jwt__Audience=EventApp.Web
Authentication__ApplicationPassword=replace-with-shared-application-password

# Initial seeded users.
